{
  "name": "markpen",
  "version": "0.0.1",
  "publisher": "Butterops",
  "engines": {
    "vscode": "^1.108.0"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "displayName": "MarkPen",
  "description": "2-in-1 Editor plus Preview for Markdown files.",
  "categories": [
    "Other"
  ],
  "icon": "assets/images/logo.png",
  "keywords": [
    "typora",
    "markdown",
    "editor",
    "wysiwyg",
    "rendering"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "bugs": {
    "url": "https://github.com/mrdotkg/vscode-markdown-2-in-1/issues",
    "email": "grv.rkg@gmail.com"
  },
  "homepage": "https://github.com/mrdotkg/vscode-markdown-2-in-1/blob/master/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrdotkg/vscode-markdown-2-in-1.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "markpen",
        "displayName": "MarkPen",
        "priority": "default",
        "selector": [
          {
            "filenamePattern": "**/*.md"
          },
          {
            "filenamePattern": "**/*.markdown"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "markpen.h0",
