{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "outDir": "out",
    "experimentalDecorators": true,
    "lib": ["es6", "es2017", "es2019", "dom"],
    "types": ["node"],
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": false
  },
  "exclude": ["node_modules", ".vscode-test"]
}